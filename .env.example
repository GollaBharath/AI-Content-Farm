PORT=8080
TTS_PORT=5002
STORAGE_DIR=./data
DB_PATH=app.db
INPUT_VIDEOS_DIR=./videos
OUTPUT_VIDEOS_DIR=./data/generated

# LLM Configuration (Gemini Primary, OpenRouter Backup)
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001

TTS_PROVIDER=piper
TTS_DOCKER_AUTO_MANAGE=true
TTS_DOCKER_SERVICE_NAME=aicf-tts
TTS_DOCKER_PROJECT_DIR=
TTS_BASE_URL=http://localhost:5002
TTS_SYNTH_PATH=/api/tts
TTS_TIMEOUT_SECONDS=30
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_VOICE_ID=
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
FFMPEG_BIN=ffmpeg
PIPER_VOICE=
PIPER_LANGUAGE=
PIPER_QUALITY=

# AutoPilot Configuration
AUTOPILOT_ENABLED=false
AUTOPILOT_EVERY_SECONDS=1800
AUTOPILOT_TOPIC=
AUTOPILOT_PROMPT=Write a high-retention script with a strong hook and punchy ending CTA.
AUTOPILOT_VOICE=
